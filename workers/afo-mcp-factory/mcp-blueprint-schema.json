{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentfeedoptimization.com/schemas/mcp-blueprint-schema.json",
  "title": "AFO MCP Factory Blueprint",
  "description": "Declarative specification consumed by afo-mcp-factory to stamp out a production-ready, stateful Cloudflare Worker MCP tool. One JSON payload -> one fully wired GitHub-committed microservice.",
  "type": "object",
  "required": ["metadata", "tools"],
  "additionalProperties": false,

  "properties": {

    "metadata": {
      "type": "object",
      "description": "Identity and versioning block. Drives worker name, wrangler.jsonc name field, and GitHub path.",
      "required": ["project_name", "namespace", "version", "description"],
      "additionalProperties": false,
      "properties": {
        "project_name": {
          "type": "string",
          "description": "Kebab-case worker name. Becomes the Cloudflare Worker script_name and the GitHub directory name under workers/.",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "namespace": {
          "type": "string",
          "description": "Reverse-domain namespace for MCP serverInfo.",
          "pattern": "^[a-z][a-z0-9.-]{2,63}$"
        },
        "version": {
          "type": "string",
          "description": "Semantic version. Written into the worker VERSION constant.",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "0.1.0"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description. Written into wrangler.jsonc and the worker status tool.",
          "minLength": 10,
          "maxLength": 280
        },
        "author": {
          "type": "string",
          "default": "nothinginfinity"
        },
        "github": {
          "type": "object",
          "required": ["owner", "repo"],
          "additionalProperties": false,
          "properties": {
            "owner":  { "type": "string", "default": "nothinginfinity" },
            "repo":   { "type": "string", "default": "repo-copilot" },
            "branch": { "type": "string", "default": "main" }
          }
        }
      }
    },

    "bindings": {
      "type": "object",
      "description": "Declarative infrastructure binding requirements. The factory generates wrangler.jsonc and resolves physical IDs at compile time.",
      "additionalProperties": false,
      "properties": {

        "d1_databases": {
          "type": "array",
          "description": "D1 SQLite databases to bind. Any d1 binding automatically gets the baseline schema (mcp_sessions + action_execution_logs) bootstrapped on first request.",
          "items": {
            "type": "object",
            "required": ["binding", "database_name"],
            "additionalProperties": false,
            "properties": {
              "binding":         { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "database_name":   { "type": "string", "pattern": "^[a-z][a-z0-9-_]{1,63}$" },
              "database_id":     { "type": "string", "pattern": "^[0-9a-f-]{36}$" },
              "auto_migrate":    { "type": "boolean", "default": true },
              "migrations_path": { "type": "string", "default": "migrations/" }
            }
          }
        },

        "kv_namespaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["binding", "namespace_title"],
            "additionalProperties": false,
            "properties": {
              "binding":         { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "namespace_title": { "type": "string", "pattern": "^[a-z][a-z0-9-_]{1,63}$" },
              "namespace_id":    { "type": "string", "pattern": "^[0-9a-f]{32}$" },
              "purpose":         { "type": "string", "enum": ["state_pointers", "locks", "cache", "routing", "config"] }
            }
          }
        },

        "r2_buckets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["binding", "bucket_name"],
            "additionalProperties": false,
            "properties": {
              "binding":                 { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "bucket_name":             { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
              "payload_threshold_bytes": { "type": "integer", "default": 2048, "minimum": 512 }
            }
          }
        },

        "vectorize_indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["binding", "index_name"],
            "additionalProperties": false,
            "properties": {
              "binding":    { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "index_name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
              "dimensions": { "type": "integer", "enum": [384, 512, 768, 1024, 1536], "default": 768 },
              "metric":     { "type": "string", "enum": ["cosine", "euclidean", "dot-product"], "default": "cosine" },
              "ai_model":   { "type": "string", "default": "@cf/baai/bge-base-en-v1.5" }
            }
          }
        },

        "ai": {
          "type": "boolean",
          "default": false
        },

        "secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name":        { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "description": { "type": "string" },
              "required":    { "type": "boolean", "default": true }
            }
          }
        }
      }
    },

    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "compatibility_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "default": "2024-11-01" },
        "auto_status_tool":   { "type": "boolean", "default": true },
        "execution_logging":  { "type": "boolean", "default": true },
        "r2_payload_offload": { "type": "boolean", "default": true },
        "vector_embedding":   { "type": "boolean", "default": false },
        "cors_origins":       { "type": "array", "items": { "type": "string" }, "default": ["*"] },
        "write_receipt":      { "type": "boolean", "default": true }
      }
    },

    "tools": {
      "type": "array",
      "description": "The MCP tools this worker exposes. Each entry generates one if-block in handle(), one TOOLS entry, and one action_execution_logs row.",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["name", "description", "handler"],
        "additionalProperties": false,
        "properties": {
          "name":         { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "description":  { "type": "string", "minLength": 10, "maxLength": 512 },
          "input_schema": {
            "type": "object",
            "properties": {
              "type":       { "type": "string", "enum": ["object"] },
              "properties": { "type": "object", "additionalProperties": { "type": "object", "required": ["type"] } },
              "required":   { "type": "array", "items": { "type": "string" } }
            }
          },
          "handler": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type":               { "type": "string", "enum": ["d1_query","d1_write","kv_get","kv_put","r2_put","r2_get","vectorize_query","vectorize_upsert","github_read","github_write","http_fetch","composite","custom"] },
              "binding":            { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "sql":                { "type": "string" },
              "sql_params":         { "type": "array", "items": { "type": "string" } },
              "kv_key_template":    { "type": "string" },
              "r2_key_template":    { "type": "string" },
              "http_url_template":  { "type": "string" },
              "http_method":        { "type": "string", "enum": ["GET","POST","PUT","PATCH","DELETE"], "default": "GET" },
              "http_auth_secret":   { "type": "string" },
              "steps":              { "type": "array" },
              "body":               { "type": "string" },
              "returns":            { "type": "object", "additionalProperties": true },
              "on_error":           { "type": "string", "enum": ["throw","return_error","return_empty"], "default": "throw" }
            }
          },
          "logging": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "skip":             { "type": "boolean", "default": false },
              "log_input":        { "type": "boolean", "default": true },
              "log_output":       { "type": "boolean", "default": true },
              "sensitive_params": { "type": "array", "items": { "type": "string" } }
            }
          },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
