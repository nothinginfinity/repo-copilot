{
  "name": "afo-transcript-capture-mcp",
  "main": "worker.js",
  "compatibility_date": "2024-11-01"
  ,"d1_databases": [
    {"binding":"DB","database_name":"afo-transcript-capture-db","database_id":"RESOLVE_AT_DEPLOY_TIME"}
  ]
  ,"kv_namespaces": [
    {"binding":"KV","id":"RESOLVE_AT_DEPLOY_TIME"}
  ]
  ,"vectorize": [
    {"binding":"VECTORIZE","index_name":"afo-transcript-vector"}
  ]
  ,"ai": {"binding":"AI"}
  ,"vars":{"WORKER_VERSION":"0.1.0","WORKER_NAME":"afo-transcript-capture-mcp"}
  ,"observability":{"enabled":true,"head_sampling_rate":1}
  ,"placement":{"mode":"smart"}
}