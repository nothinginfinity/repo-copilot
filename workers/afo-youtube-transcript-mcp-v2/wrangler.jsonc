{
  "name": "afo-youtube-transcript-mcp-v2",
  "main": "worker.js",
  "compatibility_date": "2024-11-01"
  ,"d1_databases": [
    {"binding":"DB","database_name":"afo-repo-indexer-db","database_id":"8353183f-a89e-4777-a01b-b7299b75d1c5"}
  ]
  ,"kv_namespaces": [
    {"binding":"KV","id":"RESOLVE_AT_DEPLOY_TIME"}
  ]
  ,"ai": {"binding":"AI"}
  ,"vars":{"WORKER_VERSION":"0.2.0","WORKER_NAME":"afo-youtube-transcript-mcp-v2"}
  ,"observability":{"enabled":true,"head_sampling_rate":1}
  ,"placement":{"mode":"smart"}
}