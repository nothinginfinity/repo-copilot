{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cairnstone-github-vault-mcp",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "github_stone_vault",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
